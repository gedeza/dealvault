# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/dealvault"

# Production recommendations:
# - Use connection pooling: DATABASE_URL="postgresql://...?pgbouncer=true&connection_limit=10"
# - Enable SSL: ?sslmode=require

# NextAuth
NEXTAUTH_SECRET="generate-a-strong-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# Email (Resend — get API key at https://resend.com)
# RESEND_API_KEY="re_..."
# EMAIL_FROM="DealVault <noreply@dealvault.co.za>"

# AI (Anthropic Claude API — get key at https://console.anthropic.com)
# ANTHROPIC_API_KEY="sk-ant-..."

# Node environment
NODE_ENV="development"
