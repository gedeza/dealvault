# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/dealvault"

# Production recommendations:
# - Use connection pooling: DATABASE_URL="postgresql://...?pgbouncer=true&connection_limit=10"
# - Enable SSL: ?sslmode=require

# NextAuth
NEXTAUTH_SECRET="generate-a-strong-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# Email (Resend — get API key at https://resend.com)
# RESEND_API_KEY="re_..."
# EMAIL_FROM="DealVault <noreply@dealvault.co.za>"

# AI (Anthropic Claude API — get key at https://console.anthropic.com)
# ANTHROPIC_API_KEY="sk-ant-..."

# Cloudflare R2 Object Storage (S3-compatible)
# R2_ACCOUNT_ID="your-account-id"
# R2_ACCESS_KEY_ID="your-access-key"
# R2_SECRET_ACCESS_KEY="your-secret-key"
# R2_BUCKET_NAME="dealvault"
# R2_PUBLIC_URL="https://files.dealvault.co.za"

# Google Cloud Vision (OCR for document intelligence)
# GOOGLE_APPLICATION_CREDENTIALS="/path/to/service-account.json"

# Redis (for SSE scaling across multiple processes/containers)
# REDIS_URL="redis://localhost:6379"

# Paystack Billing (get keys at https://dashboard.paystack.com)
# PAYSTACK_SECRET_KEY="sk_test_..."
# PAYSTACK_PUBLIC_KEY="pk_test_..."
# PAYSTACK_REEF_PLAN_CODE="PLN_..."        # Reef tier plan code from Paystack dashboard
# PAYSTACK_SOVEREIGN_PLAN_CODE="PLN_..."   # Sovereign tier plan code
# PAYSTACK_WEBHOOK_SECRET="whsec_..."      # Webhook signing secret

# Node environment
NODE_ENV="development"
