generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  phone         String?
  passwordHash  String
  role             String   @default("user")
  emailVerified    Boolean  @default(false)
  twoFactorEnabled Boolean  @default(false)
  twoFactorSecret  String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  companies      Company[]
  dealParties    DealParty[]
  createdDeals   Deal[]          @relation("DealCreator")
  documents      Document[]
  timelineEvents DealTimeline[]
  messages       Message[]
  passwordResets  PasswordReset[]
  notifications   Notification[]
  usedTotpCodes   UsedTotpCode[]

  // Workflow relations
  phaseApprovalDecisions PhaseApproval[]    @relation("PhaseApprovalDecider")

  // Escrow relations
  escrowBlockConfirmed    EscrowRecord[]    @relation("EscrowBlockConfirmer")
  escrowDeliveryConfirmed EscrowRecord[]    @relation("EscrowDeliveryConfirmer")
  escrowReleased          EscrowRecord[]    @relation("EscrowReleaser")
  escrowRefunded          EscrowRecord[]    @relation("EscrowRefunder")

  // Custody relations
  custodySealed            CustodyLog[]              @relation("CustodySealedBy")
  custodyReleased          CustodyLog[]              @relation("CustodyReleasedTo")
  checkpointsSubmitted     CustodyCheckpoint[]       @relation("CheckpointSubmitter")
  checkpointsConfirmed     CustodyConfirmation[]     @relation("CheckpointConfirmer")

  // Subscription & webhook relations
  subscription             Subscription?
  webhooks                 Webhook[]
}

model PasswordReset {
  id        String   @id @default(cuid())
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  userId    String
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([token])
}

model Notification {
  id        String   @id @default(cuid())
  type      String
  title     String
  message   String
  read      Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())

  userId    String
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId, read])
  @@index([userId, createdAt])
}

model Company {
  id                 String   @id @default(cuid())
  name               String
  registrationNumber String?
  taxNumber          String?
  country            String   @default("South Africa")
  verified           Boolean  @default(false)
  verifiedAt         DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  userId             String
  user               User     @relation(fields: [userId], references: [id])
  dealParties        DealParty[]
  verificationRequests VerificationRequest[]

  @@index([userId])
}

model Deal {
  id              String   @id @default(cuid())
  dealNumber      String   @unique
  title           String
  commodity       String
  quantity        Float
  unit            String
  value           Float
  currency        String   @default("USD")
  commissionPool  Float    @default(0.02)
  status          String   @default("draft")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  creatorId       String
  creator         User     @relation("DealCreator", fields: [creatorId], references: [id])

  // Workflow phase (null = legacy deal, set = escrow workflow active)
  workflowPhase   String?

  @@index([creatorId])
  @@index([status])
  @@index([commodity])
  @@index([createdAt])

  parties          DealParty[]
  documents        Document[]
  timeline         DealTimeline[]
  messages         Message[]
  commissionLedger CommissionLedger[]
  workflow         DealWorkflow?
  custodyLog       CustodyLog?
  compliance       ComplianceChecklist[]
}

model DealParty {
  id               String   @id @default(cuid())
  role             String
  side             String
  positionInChain  Int      @default(0)
  commissionPct    Float    @default(0)
  status           String   @default("invited")
  invitedAt        DateTime @default(now())
  acceptedAt       DateTime?
  verifiedAt       DateTime?

  dealId           String
  deal             Deal     @relation(fields: [dealId], references: [id])
  userId           String
  user             User     @relation(fields: [userId], references: [id])
  companyId        String?
  company          Company? @relation(fields: [companyId], references: [id])

  commissionLedger CommissionLedger[]

  @@unique([dealId, userId])
  @@index([userId])
  @@index([dealId])
}

model Document {
  id           String   @id @default(cuid())
  name         String
  type         String
  filePath     String
  fileSize     Int
  mimeType     String
  sha256Hash   String
  verified     Boolean  @default(false)
  verifiedAt   DateTime?
  visibility   String   @default("deal")
  createdAt    DateTime @default(now())

  dealId       String
  deal         Deal     @relation(fields: [dealId], references: [id])
  uploaderId   String
  uploader     User     @relation(fields: [uploaderId], references: [id])

  verificationRecord VerificationRecord? @relation("VerificationAssayDoc")

  @@index([dealId])
}

model DealTimeline {
  id          String   @id @default(cuid())
  eventType   String
  description String
  metadata    String?
  createdAt   DateTime @default(now())

  dealId      String
  deal        Deal     @relation(fields: [dealId], references: [id])
  userId      String
  user        User     @relation(fields: [userId], references: [id])

  @@index([dealId])
}

model Message {
  id         String   @id @default(cuid())
  content    String
  visibility String   @default("deal")
  createdAt  DateTime @default(now())

  dealId     String
  deal       Deal     @relation(fields: [dealId], references: [id])
  senderId   String
  sender     User     @relation(fields: [senderId], references: [id])

  @@index([dealId])
}

model CommissionLedger {
  id              String   @id @default(cuid())
  agreedPct       Float
  calculatedAmount Float
  status          String   @default("agreed")
  paidAt          DateTime?
  createdAt       DateTime @default(now())

  dealId          String
  deal            Deal     @relation(fields: [dealId], references: [id])
  partyId         String
  party           DealParty @relation(fields: [partyId], references: [id])

  @@index([dealId])
}

model UsedTotpCode {
  id        String   @id @default(cuid())
  code      String
  usedAt    DateTime @default(now())

  userId    String
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, code])
  @@index([userId])
  @@index([usedAt])
}

// ============================================================================
// Escrow Workflow Models
// ============================================================================

model DealWorkflow {
  id             String    @id @default(cuid())
  phase          String    @default("listing")
  phaseStartedAt DateTime  @default(now())
  phaseDeadline  DateTime?
  completedAt    DateTime?
  cancelledAt    DateTime?
  cancelReason   String?
  disputedAt     DateTime?
  disputeReason  String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  dealId         String    @unique
  deal           Deal      @relation(fields: [dealId], references: [id])

  phaseApprovals     PhaseApproval[]
  verificationRecord VerificationRecord?
  escrow             EscrowRecord?

  @@index([dealId])
  @@index([phase])
}

model PhaseApproval {
  id           String    @id @default(cuid())
  phase        String
  action       String    @default("pending")
  requiredRole String
  status       String    @default("pending")
  notes        String?
  decidedAt    DateTime?
  createdAt    DateTime  @default(now())

  workflowId   String
  workflow     DealWorkflow @relation(fields: [workflowId], references: [id])
  decidedById  String?
  decidedBy    User?     @relation("PhaseApprovalDecider", fields: [decidedById], references: [id])

  @@index([workflowId, phase])
  @@index([workflowId, status])
}

model VerificationRecord {
  id               String    @id @default(cuid())
  location         String?
  scheduledAt      DateTime?
  completedAt      DateTime?
  inspectorName    String?
  inspectorCompany String?
  result           String?
  findings         String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  workflowId       String    @unique
  workflow         DealWorkflow @relation(fields: [workflowId], references: [id])

  assayDocumentId  String?   @unique
  assayDocument    Document? @relation("VerificationAssayDoc", fields: [assayDocumentId], references: [id])

  @@index([workflowId])
}

model EscrowRecord {
  id                    String    @id @default(cuid())
  currency              String
  amount                Float
  status                String    @default("pending")
  referenceNumber       String?
  notes                 String?

  blockedAt             DateTime?
  blockConfirmedAt      DateTime?
  blockConfirmedById    String?
  blockConfirmedBy      User?     @relation("EscrowBlockConfirmer", fields: [blockConfirmedById], references: [id])

  deliveryConfirmedAt   DateTime?
  deliveryConfirmedById String?
  deliveryConfirmedBy   User?     @relation("EscrowDeliveryConfirmer", fields: [deliveryConfirmedById], references: [id])

  releasedAt            DateTime?
  releasedById          String?
  releasedBy            User?     @relation("EscrowReleaser", fields: [releasedById], references: [id])

  refundedAt            DateTime?
  refundedById          String?
  refundedBy            User?     @relation("EscrowRefunder", fields: [refundedById], references: [id])

  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  workflowId            String    @unique
  workflow              DealWorkflow @relation(fields: [workflowId], references: [id])

  @@index([workflowId])
  @@index([status])
}

// ============================================================================
// Chain of Custody Models
// ============================================================================

model CustodyLog {
  id             String    @id @default(cuid())
  sealId         String
  status         String    @default("initiated")

  sealedAt       DateTime?
  sealedByUserId String?
  sealedByUser   User?     @relation("CustodySealedBy", fields: [sealedByUserId], references: [id])
  sealPhotoPath  String?
  sealPhotoHash  String?

  custodianName    String?
  custodianType    String?
  custodianContact String?

  releasedAt       DateTime?
  releasedToUserId String?
  releasedToUser   User?     @relation("CustodyReleasedTo", fields: [releasedToUserId], references: [id])

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  dealId         String    @unique
  deal           Deal      @relation(fields: [dealId], references: [id])

  checkpoints    CustodyCheckpoint[]

  @@index([dealId])
  @@index([sealId])
}

model CustodyCheckpoint {
  id              String    @id @default(cuid())
  sequence        Int
  checkpointType  String
  label           String

  latitude        Float?
  longitude       Float?
  locationName    String?

  notes           String?
  sealIntact      Boolean?
  weight          Float?
  weightUnit      String?

  photoPath       String?
  photoHash       String?
  videoPath       String?
  videoHash       String?

  submittedByUserId String?
  submittedByUser   User?    @relation("CheckpointSubmitter", fields: [submittedByUserId], references: [id])
  submittedAt       DateTime?

  isMandatory     Boolean   @default(true)
  isComplete      Boolean   @default(false)
  completedAt     DateTime?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  custodyLogId    String
  custodyLog      CustodyLog @relation(fields: [custodyLogId], references: [id])

  confirmations   CustodyConfirmation[]

  @@index([custodyLogId])
  @@index([custodyLogId, sequence])
}

model CustodyConfirmation {
  id                String   @id @default(cuid())
  partyRole         String
  side              String
  status            String
  disputeReason     String?
  confirmedAt       DateTime @default(now())

  checkpointId      String
  checkpoint        CustodyCheckpoint @relation(fields: [checkpointId], references: [id])
  confirmedByUserId String
  confirmedByUser   User     @relation("CheckpointConfirmer", fields: [confirmedByUserId], references: [id])

  @@unique([checkpointId, confirmedByUserId])
  @@index([checkpointId])
}

// ============================================================================
// Subscription & Billing Models (Stripe)
// ============================================================================

model Subscription {
  id                    String    @id @default(cuid())
  tier                  String    @default("prospect") // prospect, reef, sovereign, vault
  status                String    @default("active") // active, past_due, cancelled, trialing
  provider              String    @default("paystack") // paystack, flutterwave
  providerCustomerId    String?   @unique // e.g. Paystack CUS_xxx
  providerSubscriptionId String?  @unique // e.g. Paystack SUB_xxx
  providerPlanCode      String?            // e.g. Paystack PLN_xxx
  providerEmail         String?            // email registered with payment provider
  trialEndsAt           DateTime?
  currentPeriodStart    DateTime?
  currentPeriodEnd      DateTime?
  cancelledAt           DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  userId                String    @unique
  user                  User      @relation(fields: [userId], references: [id])

  invoices              Invoice[]

  @@index([userId])
  @@index([providerCustomerId])
  @@index([status])
}

model Invoice {
  id                String    @id @default(cuid())
  providerInvoiceId String?   @unique // e.g. Paystack invoice reference
  amount            Float
  currency          String    @default("ZAR")
  status            String    @default("pending") // pending, paid, failed, void
  paidAt            DateTime?
  invoiceUrl        String?
  createdAt         DateTime  @default(now())

  subscriptionId    String
  subscription      Subscription @relation(fields: [subscriptionId], references: [id])

  @@index([subscriptionId])
  @@index([status])
}

// ============================================================================
// Compliance Models
// ============================================================================

model ComplianceChecklist {
  id                String    @id @default(cuid())
  framework         String    // sadpmr, fica_aml, kimberley_process, lbma
  status            String    @default("pending") // pending, in_progress, compliant, non_compliant
  completedAt       DateTime?
  reviewedByUserId  String?
  reviewNotes       String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  dealId            String
  deal              Deal      @relation(fields: [dealId], references: [id])

  items             ComplianceItem[]

  @@unique([dealId, framework])
  @@index([dealId])
  @@index([status])
}

model ComplianceItem {
  id              String    @id @default(cuid())
  requirement     String
  description     String
  status          String    @default("pending") // pending, met, not_met, na
  evidenceNote    String?
  documentId      String?   // optional link to uploaded document as evidence
  completedAt     DateTime?
  createdAt       DateTime  @default(now())

  checklistId     String
  checklist       ComplianceChecklist @relation(fields: [checklistId], references: [id])

  @@index([checklistId])
}

// ============================================================================
// Company Verification
// ============================================================================

model VerificationRequest {
  id              String    @id @default(cuid())
  status          String    @default("pending") // pending, approved, rejected
  documentIds     String?   // comma-separated document IDs (KYC docs)
  reviewedByUserId String?
  reviewNotes     String?
  requestedAt     DateTime  @default(now())
  reviewedAt      DateTime?

  companyId       String
  company         Company   @relation(fields: [companyId], references: [id])

  @@index([companyId])
  @@index([status])
}

// ============================================================================
// Webhook Integration
// ============================================================================

model Webhook {
  id           String    @id @default(cuid())
  url          String
  platform     String    // slack, teams, custom
  events       String    // comma-separated event types
  secret       String?
  active       Boolean   @default(true)
  lastFiredAt  DateTime?
  failCount    Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  userId       String
  user         User      @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([active])
}
